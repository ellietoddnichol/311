# App Settings
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=estimator.db

# AI Integration
# Note: This is an API key from Google AI Studio/Vertex for Gemini models.
# A Google service account JSON does NOT replace this key.
GEMINI_API_KEY=
# Alternate key name is also supported
GOOGLE_GEMINI_API_KEY=

# Google Sheets Sync
# Preferred local setup: store the service-account JSON as
# ./google-service-account.json and point GOOGLE_SERVICE_ACCOUNT_FILE at it.
# Use ONE auth method below:
# 1) Full JSON in a single env var (fallback)
GOOGLE_SERVICE_ACCOUNT=
# 2) Service account file path (recommended)
GOOGLE_SERVICE_ACCOUNT_FILE=./google-service-account.json
# 3) Split credentials (fallback)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Spreadsheet and tab config
GOOGLE_SHEETS_SPREADSHEET_ID=1QWCGCssWtAQ8Pjx9_-7LDs4lraRbptURd8D04bNvnEg
GOOGLE_SHEETS_TAB_ITEMS=ITEMS
GOOGLE_SHEETS_TAB_MODIFIERS=MODIFIERS
GOOGLE_SHEETS_TAB_BUNDLES=BUNDLES

# Project file uploads (drawings / takeoffs) — Google Cloud Storage
# When set (with the same service account credentials as Sheets), new uploads are
# stored in the bucket instead of Base64 inside SQLite. Leave unset for local/dev inline storage.
# Grant the service account: Storage Object Admin (or custom: create/delete objects on this bucket).
GCS_PROJECT_FILES_BUCKET=

# Backward-compatible legacy keys
GOOGLE_SHEETS_ID=
GOOGLE_CLIENT_EMAIL=

# --- Postgres & Supabase (optional; 311+install331 integration) ---
# Default local dev remains SQLite (see src/server/db.ts and estimator.db on disk).
# For Postgres/Supabase pooler, set:
# DB_DRIVER=pg
# DATABASE_URL=postgresql://...  (Supabase "Transaction" pooler or local Postgres)
# Optional SSL root cert (Supabase `prod-ca-2021.crt`), for clients/networks that require explicit CA:
# PG_SSL_CA_PATH=./prod-ca-2021.crt
# PG_SSL_REJECT_UNAUTHORIZED=1
# AUTH_REQUIRED=0 is typical for local; set 1 to require session on /api/v1
DB_DRIVER=sqlite
AUTH_REQUIRED=0
SUPABASE_URL=https://jqivtdceqwfbzqdyvoth.supabase.co
SUPABASE_ANON_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
