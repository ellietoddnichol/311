# App Settings
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=estimator.db

# AI Integration
# Note: This is an API key from Google AI Studio/Vertex for Gemini models.
# A Google service account JSON does NOT replace this key.
GEMINI_API_KEY=
# Alternate key name is also supported
GOOGLE_GEMINI_API_KEY=

# Google Sheets Sync
# Use ONE auth method below (leave others empty).
# Cloud Run / production: put the full service-account JSON in Secret Manager as
# GOOGLE_SERVICE_ACCOUNT, or set GOOGLE_SERVICE_ACCOUNT_EMAIL + GOOGLE_PRIVATE_KEY.
# Local only: you may set GOOGLE_SERVICE_ACCOUNT_FILE to a path such as
# ./google-service-account.json (do not commit that file).
# 1) Full JSON in a single env var (best for Cloud Run secrets)
GOOGLE_SERVICE_ACCOUNT=
# 2) Path to JSON file (local dev only; leave empty on Cloud Run)
GOOGLE_SERVICE_ACCOUNT_FILE=
# 3) Split credentials
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Spreadsheet and tab config
GOOGLE_SHEETS_SPREADSHEET_ID=1QWCGCssWtAQ8Pjx9_-7LDs4lraRbptURd8D04bNvnEg
GOOGLE_SHEETS_TAB_ITEMS=ITEMS
GOOGLE_SHEETS_TAB_MODIFIERS=MODIFIERS
GOOGLE_SHEETS_TAB_BUNDLES=BUNDLES

# Backward-compatible legacy keys
GOOGLE_SHEETS_ID=
GOOGLE_CLIENT_EMAIL=
